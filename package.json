{
  "name": "@ching-payments/cli",
  "version": "0.1.1",
  "description": "Command-line interface for CHING. Manage products, prices, and customers from your terminal.",
  "type": "module",
  "bin": {
    "ching": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.0",
    "open": "^10.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}